<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1A1D2E"/>
      <stop offset="100%" stop-color="#0D0F1A"/>
    </linearGradient>
    <linearGradient id="g1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7C6BFF"/>
      <stop offset="100%" stop-color="#22D3EE"/>
    </linearGradient>
    <linearGradient id="g2" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#7C6BFF"/>
      <stop offset="100%" stop-color="#F472B6"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="512" height="512" rx="110" fill="url(#bg)"/>

  <!-- Subtle background glow -->
  <circle cx="160" cy="180" r="180" fill="#7C6BFF" opacity="0.06"/>
  <circle cx="380" cy="360" r="140" fill="#22D3EE" opacity="0.05"/>

  <!-- Document body -->
  <rect x="100" y="80" width="220" height="290" rx="24"
        fill="none" stroke="url(#g1)" stroke-width="14"/>

  <!-- Folded corner -->
  <path d="M244 80 L320 156" fill="none" stroke="url(#g1)" stroke-width="14" stroke-linecap="round"/>
  <path d="M244 80 L244 156 L320 156" fill="url(#g1)" opacity="0.15" stroke="none"/>

  <!-- Document lines -->
  <line x1="136" y1="210" x2="284" y2="210" stroke="url(#g1)" stroke-width="12" stroke-linecap="round" opacity="0.8"/>
  <line x1="136" y1="250" x2="284" y2="250" stroke="url(#g1)" stroke-width="12" stroke-linecap="round" opacity="0.6"/>
  <line x1="136" y1="290" x2="220" y2="290" stroke="url(#g1)" stroke-width="12" stroke-linecap="round" opacity="0.4"/>
  <line x1="136" y1="330" x2="260" y2="330" stroke="url(#g1)" stroke-width="12" stroke-linecap="round" opacity="0.3"/>

  <!-- AI Spark badge circle - outer glow -->
  <circle cx="360" cy="360" r="108" fill="#7C6BFF" opacity="0.12" filter="url(#glow)"/>

  <!-- AI Spark badge -->
  <circle cx="360" cy="360" r="95" fill="#0D0F1A"/>
  <circle cx="360" cy="360" r="95" fill="url(#g2)" opacity="0.15"/>
  <circle cx="360" cy="360" r="90" fill="none" stroke="url(#g2)" stroke-width="6"/>

  <!-- 4-point star / spark -->
  <path d="
    M360 290
    L374 346
    L430 360
    L374 374
    L360 430
    L346 374
    L290 360
    L346 346
    Z"
    fill="url(#g2)" filter="url(#glow)"/>

  <!-- Small sparkle dots around star -->
  <circle cx="416" cy="304" r="7" fill="#F472B6" opacity="0.8"/>
  <circle cx="308" cy="416" r="5" fill="#7C6BFF" opacity="0.7"/>
  <circle cx="308" cy="304" r="4" fill="#22D3EE" opacity="0.6"/>
</svg>
